# Compiled source
# =========================

*.dll
*.exe
*.obj
*.pdb
*.lib
*.exp

# =========================
# Unreal Build Tool
# =========================

*.Target.cs.json

# =========================
# Temporary files
# =========================

*.tmp
*.temp

# =========================
# Python / tools (if any)
